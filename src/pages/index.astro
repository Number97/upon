---
import '../styles/global.css'

const socials = [
  { name: 'Instagram', url: 'https://instagram.com/uponground', icon: 'instagram' },
  { name: 'YouTube', url: 'https://www.youtube.com/@uponhub/', icon: 'youtube' },
  { name: 'SoundCloud', url: 'https://soundcloud.com/uponground', icon: 'soundcloud' },
  { name: 'Bandcamp', url: 'https://uponground.bandcamp.com/', icon: 'bandcamp' },
  { name: 'Telegram', url: 'https://t.me/uponhub', icon: 'telegram' },
]

const releases = [
  { title: 'Seamless Blend [UPG-SB001]', url: 'https://on.soundcloud.com/kBPnDGJZzIj4mLwkDM' },
  { title: 'PAKZ - Channel 2', url: 'https://www.youtube.com/watch?v=pbrWMw7OA0o' },
  { title: 'Nichel - Romanian Dream [UPG002]', url: 'https://www.youtube.com/watch?v=LBL9Ad7jOu8' },
  { title: 'Raffers - Dialog [UPG001]', url: 'https://www.youtube.com/watch?v=hRxR9aYpAmY' },
]

const podcasts = [
  { title: "Geolyna Georgia - Celebrating Women's Day [UPC001]", url: 'https://on.soundcloud.com/j4hArARmAQDToJvn8O' },
]

const email = 'upongroundhub@gmail.com'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Uponground - electronic music platform" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>Uponground</title>
  </head>
  <body class="bg-blue text-light font-sans min-h-screen flex items-center justify-center antialiased selection:bg-dark selection:text-light">
    <main class="w-full max-w-md mx-auto px-6 py-20 flex flex-col items-center gap-12">

      <!-- Logo -->
      <div class="w-24 h-24">
        <img src="/logo.svg" alt="Uponground" class="w-full h-full" />
      </div>

      <!-- Name & Bio -->
      <div class="text-center space-y-3">
        <h1 class="text-3xl font-semibold tracking-wide uppercase">Uponground</h1>
        <p class="text-gray text-sm font-light tracking-[0.2em] uppercase">Electronic Music Platform</p>
      </div>

      <!-- Social Icons -->
      <nav class="flex items-center gap-6" aria-label="Social links">
        {socials.map(({ name, url, icon }) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={name}
            class="text-light/50 hover:text-light transition-colors duration-200"
          >
            <svg class="w-[18px] h-[18px] fill-current" role="img" aria-hidden="true">
              <use href={`/icons.svg#${icon}`} />
            </svg>
          </a>
        ))}
        <a
          href={`mailto:${email}`}
          aria-label="Email"
          class="text-light/50 hover:text-light transition-colors duration-200"
        >
          <svg class="w-[18px] h-[18px] fill-current" role="img" aria-hidden="true">
            <use href="/icons.svg#email" />
          </svg>
        </a>
      </nav>

      <!-- Divider -->
      <div class="w-8 h-px bg-gray/20"></div>

      <!-- Releases -->
      <div class="w-full flex flex-col gap-3">
        <p class="text-xs text-gray font-medium tracking-widest uppercase text-center mb-2">Releases</p>
        {releases.map(({ title, url }) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center py-4 px-5 bg-dark rounded-lg text-sm font-normal tracking-wide text-light hover:bg-dark/80 transition-all duration-200"
          >
            {title}
          </a>
        ))}
      </div>

      <!-- Divider -->
      <div class="w-8 h-px bg-gray/20"></div>

      <!-- Podcasts -->
      <div class="w-full flex flex-col gap-3">
        <p class="text-xs text-gray font-medium tracking-widest uppercase text-center mb-2">Podcasts</p>
        {podcasts.map(({ title, url }) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center py-4 px-5 bg-dark rounded-lg text-sm font-normal tracking-wide text-light hover:bg-dark/80 transition-all duration-200"
          >
            {title}
          </a>
        ))}
      </div>

      <!-- Coming Soon -->
      <p class="text-xs text-gray/40 font-light tracking-[0.25em] uppercase mt-2">More Coming Soon</p>

    </main>
  </body>
</html>
